<% content_for :title, "Showing cart" %>
<% if @cart.id == session[:cart_id] %>
  <div class="md:w-2/3 w-full">
    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
    <% end %>

    <h1 class="font-bold text-4xl">Showing cart</h1>

    <%= render @cart %>

  </div>
<% else %>
  <div class="md:w-2/3 w-full">
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-md inline-block">You don't have permission to view this cart.</p>
    <%= link_to "Return to store", store_index_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white block font-medium" %>
  </div>
<% end %>
